# Copy this file to .env and fill in your values.
# Never commit .env to git!

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Google Auth ───────────────────────────────────────────────────────────────
# For Render / production  →  AUTH_MODE=service_account
# For local dev with OAuth →  AUTH_MODE=oauth  (needs credentials.json)
AUTH_MODE=service_account

# Paste the full service-account JSON on ONE line, or base64-encode it first:
#   base64 -i service-account.json | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Calendar ──────────────────────────────────────────────────────────────────
# "primary" = your main calendar, or use a specific calendar's email address
CALENDAR_ID=primary

# ── Timing ───────────────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=60       # how often to poll (seconds)
REMINDER_MINUTES_AHEAD=30      # first reminder (minutes before event)
CLOSE_REMINDER_MINUTES=10      # second reminder (minutes before event)
MORNING_DIGEST_HOUR=8          # hour (0-23) to send the daily digest
